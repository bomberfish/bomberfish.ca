{
	"name": "website",
	"private": true,
	"packageManager": "pnpm@10.12.4",
	"version": "9.5.2",
	"type": "module",
	"scripts": {
		"dev": "vite",
		"build:client": "tsc && vite build --ssrManifest .vite/ssr-manifest.json --outDir dist/static",
		"build:server": "tsc && vite build --ssr src/main-server.ts --outDir dist/server",
