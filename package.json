		"@vitejs/plugin-legacy": "^7.2.1",
		"@wooorm/starry-night": "^3.8.0",
		"autoprefixer": "^10.4.22",
		"css-declaration-sorter": "7.3.0",
		"cssnano": "^7.1.2",
		"cssnano-preset-lite": "^4.0.4",
		"esbuild": "^0.27.0",
		"estree-util-visit": "^2.0.0",
		"feed": "^5.1.0",
		"lightningcss": "^1.30.2",
		"postcss": "^8.5.6",
		"postcss-calc": "10.1.1",
		"postcss-cli": "^11.0.1",
